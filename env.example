# انسخ هذا الملف إلى .env واملأ القيم الفعلية — لا ترفع .env أبداً لأي مكان عام (GitHub إلخ)
# في الإنتاج (Railway)، تُضاف هذه كلها في Variables مباشرة، وليس كملف .env

# ── مزودو RPC/HTTP (يكفي واحد على الأقل، والأفضل عدة معاً للتناوب التلقائي) ──
ALCHEMY_API_KEY=
HELIUS_API_KEY=
CHAINSTACK_RPC_URL=
CHAINSTACK_WS_URL=
ANKR_RPC_URL=
GETBLOCK_RPC_URL=
GETBLOCK_WS_URL=
DRPC_API_KEY=

# Tatum: تأكيد أخير مستقل قبل الشراء فقط (fail-open — اختياري لكن موصى به)
TATUM_API_KEY=

# ── فحوصات الأمان والتداول ──
GOPLUS_APP_KEY=
GOPLUS_APP_SECRET=
JUPITER_API_KEY=

# ── قاعدة البيانات (Postgres) — أساسية + احتياطية مع تبديل تلقائي ──
DATABASE_URL=
FALLBACK_DATABASE_URL=

# ── تيليجرام (إشعارات فتح/إغلاق الصفقات + الأداء التراكمي) ──
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── المحفظة والتداول ──
# ابدأ دائماً بـ true (Devnet) حتى تختبر البوت بالكامل
USE_DEVNET=true
# لا تضع هنا مفتاحاً خاصاً حقيقياً إلا بعد اختبار كامل على Devnet
WALLET_PRIVATE_KEY=

# فلاتر الشريعة (كلمات محظورة: قمار، ربا، محتوى غير لائق) — مفعّلة افتراضياً
SHARIA_FILTERS_ENABLED=true
